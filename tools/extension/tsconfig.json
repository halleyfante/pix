  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "distribution",
    "rootDir": "source",
    "declaration": true
  },
  "include": ["source/**/*.ts"]
}
